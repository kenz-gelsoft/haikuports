SUMMARY="Unofficial Haiku port of Mozilla Firefox"
DESCRIPTION="Iceweasel is an open source web browser. \
It achieves balance between ease of use and customization, catering to the \
needs of both casual and power users."
HOMEPAGE="https://github.com/kenz-gelsoft/gecko-dev"
COPYRIGHT="1995-2024 Mozilla Developers and Contributors"
LICENSE="MPL v2.0"
REVISION="1"
buildTag="HAIKU128_5_20241206"
SOURCE_URI="https://github.com/kenz-gelsoft/gecko-dev/releases/download/$buildTag/firefox-$portVersion.en-US.haiku-x86_64.tar.bz2#noarchive"
CHECKSUM_SHA256="311720a084a87da790ed3f992499f939d76e0259387c706336c3c56581bf65f0"
ADDITIONAL_FILES="iceweasel_icon.hvif"

ARCHITECTURES="x86_64"
DISABLE_SOURCE_PACKAGE="true"

PROVIDES="
	iceweasel_bin = $portVersion
	app:Iceweasel = $portVersion
	cmd:iceweasel = $portVersion
	"
REQUIRES="
	haiku
	lib:libatk_1.0
	lib:libcairo
	lib:libcairo_gobject
	lib:libgdk_3
	lib:libgdk_pixbuf_2.0
	lib:libgio-2.0
	lib:libglib_2.0
	lib:libgobject-2.0
	lib:libgtk_3
	lib:libharfbuzz
	lib:libintl
	lib:libnspr4
	lib:libnss3
	lib:libpango_1.0
	lib:libpangocairo_1.0
	lib:libpng16
	lib:libz
	"

INSTALL()
{
	mkdir -p $appsDir
	tar jxf firefox-$portVersion.en-US.haiku-x86_64.tar.bz2 -C $appsDir
	mv $appsDir/{firefox,Iceweasel}

	cd $appsDir/Iceweasel
	mv firefox Iceweasel

	# arranging the files in lib directories
	mkdir -p $appsDir/Iceweasel/lib
	# NSS libs
	# mv \
	#	libfreebl3.so        \
	#	libnss3.so           \
	#	libnssckbi.so        \
	#	libnssutil3.so       \
	#	libsmime3.so         \
	#	libsoftokn3.so       \
	#	libssl3.so           \
	#	lib
	mv \
		libgkcodecs.so       \
		libipcclientcerts.so \
		liblgpllibs.so       \
		libmozavcodec.so     \
		libmozavutil.so      \
		libmozgtk.so         \
		libmozsqlite3.so     \
		libmozwayland.so     \
		libxul.so            \
		lib

	addattr -t icon -f $portDir/additional-files/iceweasel_icon.hvif \
		"BEOS:ICON" $appsDir/Iceweasel/Iceweasel
	addAppDeskbarSymlink $appsDir/Iceweasel/Iceweasel
}
