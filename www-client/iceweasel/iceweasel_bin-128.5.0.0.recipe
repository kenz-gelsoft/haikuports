SUMMARY="Unofficial Haiku port of Mozilla Firefox"
DESCRIPTION="Iceweasel is an open source web browser. \
It achieves balance between ease of use and customization, catering to the \
needs of both casual and power users."
HOMEPAGE="https://github.com/kenz-gelsoft/gecko-dev"
COPYRIGHT="1995-2024 Mozilla Developers and Contributors"
LICENSE="MPL v2.0"
REVISION="1"
SOURCE_URI="https://github.com/kenz-gelsoft/gecko-dev/releases/download/HAIKU128_5_20241206/firefox-128.5.0.en-US.haiku-x86_64.tar.bz2"
CHECKSUM_SHA256="311720a084a87da790ed3f992499f939d76e0259387c706336c3c56581bf65f0"
SOURCE_DIR="firefox"
#PATCHES="gecko-dev-$portVersion.patch"
ADDITIONAL_FILES="iceweasel_icon.hvif"

ARCHITECTURES="x86_64"

PROVIDES="
	iceweasel= $portVersion
	app:Iceweasel= $portVersion
	cmd:iceweasel= $portVersion
	"
REQUIRES="
	haiku
	lib:libatk_1.0
	lib:libcairo
	lib:libcairo_gobject
	lib:libgdk_3
	lib:libgdk_pixbuf_2.0
	lib:libglib_2.0
	lib:libgtk_3
	lib:libharfbuzz
	lib:libintl
	lib:libnspr4
	lib:libnss3
	lib:libpango_1.0
	lib:libpangocairo_1.0
	lib:libpng16
	lib:libz
	"

BUILD_REQUIRES="
#	haiku_devel
#	devel:libdbus_1
#	devel:libdbus_glib_1
#	devel:libevent
#	devel:libglib_2.0
#	devel:libgtk_3
#	devel:libnspr4
#	devel:libnss3
#	devel:libpng16
#	devel:libvpx
#	devel:libwebp
#	devel:libzstd
	"
BUILD_PREREQUIRES="
#	llvm18
#	nodejs16
#	rust_bin
#	cmd:autoconf_2.13
#	cmd:cbindgen
#	cmd:clang++
#	cmd:gawk
#	# We need gcc even if we use clang to compile.
#	cmd:gcc
#	cmd:git
#	cmd:m4
