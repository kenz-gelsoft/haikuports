SUMMARY="Unofficial Haiku port of Mozilla Firefox"
DESCRIPTION="Iceweasel is an open source web browser. \
It achieves balance between ease of use and customization, catering to the \
needs of both casual and power users."
HOMEPAGE="https://github.com/kenz-gelsoft/gecko-dev"
COPYRIGHT="1995-2024 Mozilla Developers and Contributors"
LICENSE="MPL v2.0"
REVISION="1"
srcGitRev="e14b3e7bef82510f279f5592ee901bd349f96099"
SOURCE_URI="https://github.com/kenz-gelsoft/gecko-dev/archive/$srcGitRev.zip"
CHECKSUM_SHA256="133787a35fd8d8cc2cf816070b73127b53f4f300204b8f58a06754c0f02b4cf5"
SOURCE_DIR="gecko-dev-$srcGitRev"
PATCHES="gecko-dev-$portVersion.patch"
ADDITIONAL_FILES="iceweasel_icon.hvif"

ARCHITECTURES="x86_64"

PROVIDES="
	iceweasel= $portVersion
	app:Iceweasel= $portVersion
	cmd:iceweasel= $portVersion
	"
REQUIRES="
	haiku
	lib:libatk_1.0
	lib:libcairo
	lib:libcairo_gobject
	lib:libgdk_3
	lib:libgdk_pixbuf_2.0
	lib:libglib_2.0
	lib:libgtk_3
	lib:libharfbuzz
	lib:libintl
	lib:libnspr4
	lib:libpango_1.0
	lib:libpangocairo_1.0
	lib:libpng16
	lib:libz
	"

BUILD_REQUIRES="
	haiku_devel
	devel:libdbus_1
	devel:libdbus_glib_1
	devel:libevent
	devel:libglib_2.0
	devel:libgtk_3
	devel:libnspr4
	devel:libpng16
	devel:libvpx
	devel:libwebp
	devel:libzstd
	"
BUILD_PREREQUIRES="
	llvm18
	nodejs16
	rust_bin
	cmd:autoconf_2.13
	cmd:cbindgen
	cmd:clang++
	cmd:gawk
	# We need gcc even if we use clang to compile.
	cmd:gcc
	cmd:git
	cmd:m4
	cmd:make
	cmd:nasm
	cmd:perl
	cmd:pip3
	cmd:pkg_config
	cmd:python3
	cmd:tar
	cmd:xargs
	cmd:zip
	"

BUILD()
{
	chmod +x \
		build/cargo-linker \
		mach

	rm -f mozconfig
	cp haiku_mozconfig mozconfig
	echo "ac_add_options --with-app-name=Iceweasel" >> mozconfig

	./mach -vv \
		--no-interactive bootstrap \
		--application-choice="Firefox for Desktop" \
		--exclude=sysroot-wasm32-wasi

	./mach build
}

INSTALL()
{
	./mach install

	mkdir -p $appsDir

	# TODO: /usr/local/lib => $libDir
	mv /usr/local/lib/Iceweasel $appsDir/Iceweasel

	mkdir -p $appsDir/Iceweasel/lib

	# arranging the files in lib directories
	cd $appsDir/Iceweasel
	mv \
		libfreebl3.so        \
		libgkcodecs.so       \
		libipcclientcerts.so \
		liblgpllibs.so       \
		libmozavcodec.so     \
		libmozavutil.so      \
		libmozgtk.so         \
		libmozsqlite3.so     \
		libmozwayland.so     \
		libnss3.so           \
		libnssckbi.so        \
		libnssutil3.so       \
		libsmime3.so         \
		libsoftokn3.so       \
		libssl3.so           \
		libxul.so            \
		lib

	addattr -t icon -f $portDir/additional-files/iceweasel_icon.hvif \
		"BEOS:ICON" $appsDir/Iceweasel/Iceweasel
	addAppDeskbarSymlink $appsDir/Iceweasel/Iceweasel
}
